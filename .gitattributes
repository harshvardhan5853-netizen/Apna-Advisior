# ─── Auto-detect text files ──────────────────────────────────────
* text=auto

# ─── Normalize to LF (all platforms) ─────────────────────────────
*.js     text eol=lf
*.jsx    text eol=lf
*.ts     text eol=lf
*.tsx    text eol=lf
*.mjs    text eol=lf
*.cjs    text eol=lf
*.json   text eol=lf
*.css    text eol=lf
*.html   text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.toml   text eol=lf
*.md     text eol=lf
*.sh     text eol=lf

# ─── Windows-native scripts ──────────────────────────────────────
*.bat    text eol=crlf
*.ps1    text eol=crlf

# ─── Binary artifacts (never transform) ──────────────────────────
*.ico    binary
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.webp   binary
*.woff   binary
*.woff2  binary
*.eot    binary
*.ttf    binary
